{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Staff Daily Report",
  "version": "1.0.0",
  "identifier": "com.staffdailyreport.app",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://127.0.0.1:8000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Staff Daily Report",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
